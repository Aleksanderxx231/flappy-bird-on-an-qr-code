data:text/html,<!DOCTYPE html><html><head><meta charset="utf-8"><title>B</title><style>body{margin:0;background:%23000;display:flex;justify-content:center;align-items:center;height:100vh}canvas{background:%2370c5ce;max-width:100vw;max-height:100vh}</style></head><body><canvas id="c" width="400" height="600"></canvas><script>const x=c.getContext("2d");let y=300,v=0,s=0,h=0,o=!1,p=[];const r=()=>p.length&&p[0].x<-60?p.shift():0;onkeydown=e=>e.code=="Space"?(o?g():v=-5.5):0;onpointerdown=()=>(o?g():v=-5.5);const g=()=>{y=300;v=0;s=0;o=!1;p=[{x:400,t:150}]};g();setInterval(()=>{x.fillStyle="%2370c5ce";x.fillRect(0,0,400,600);if(!o){v+=.25;y+=v}if(!p.length||p[p.length-1].x<240)p.push({x:400,t:Math.random()*250+50});p.forEach(i=>{if(!o)i.x-=2;x.fillStyle="%2373c739";x.fillRect(i.x,0,60,i.t);x.fillRect(i.x,i.t+140,60,600);if(i.x<127&&i.x+60>103&&(y-12<i.t||y+12>i.t+140))o=!0;if(!i.d&&i.x+60<103){i.d=!0;s++;if(s>h)h=s}});r();if(y>588||y<12)o=!0;x.fillStyle="%23f8e71c";x.beginPath();x.arc(115,y,12,0,7);x.fill();x.fillStyle="%23ff5722";x.fillRect(123,y-4,8,6);x.fillStyle="%23fff";x.font="24px sans-serif";if(!o){x.fillText(s,20,40)}else{x.fillStyle="rgba(0,0,0,.4)";x.fillRect(0,0,400,600);x.fillStyle="%23fff";x.textAlign="center";x.fillText("GAME OVER",200,260);x.fillText(`Score: ${s} | Best: ${h}`,200,300);x.fillText("TAP / SPACE",200,340);x.textAlign="left"}},16);</script></body></html>
